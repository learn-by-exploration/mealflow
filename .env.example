# MealFlow Environment Configuration
# Copy this file to .env and adjust values as needed.
# All values shown are defaults — the app works without a .env file.

# Server
PORT=3458
HOST=0.0.0.0               # Bind address (use 0.0.0.0 for Docker/LAN access)
NODE_ENV=development

# Database directory (where mealflow.db lives)
DB_DIR=./data

# Logging
LOG_LEVEL=info          # silent | error | warn | info | debug

# Session
SESSION_MAX_AGE_DAYS=7
SESSION_REMEMBER_DAYS=30

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=200

# Auth Rate Limiting
AUTH_LIMIT_WINDOW_MS=900000
AUTH_LIMIT_MAX=20

# Bcrypt
BCRYPT_SALT_ROUNDS=12

# Backup
BACKUP_RETAIN_COUNT=7
BACKUP_INTERVAL_HOURS=24

# Graceful Shutdown
SHUTDOWN_TIMEOUT_MS=10000

# Base URL (for behind reverse proxy)
# BASE_URL=
# TRUST_PROXY=false

# CORS (comma-separated origins, empty = same-origin only)
ALLOWED_ORIGINS=http://localhost:3458

# Per-user rate limit (max requests per user per window)
RATE_LIMIT_PER_USER_MAX=100
