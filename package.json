{
  "name": "mealflow",
  "version": "1.0.0",
  "description": "Self-hosted meal planner & nutrition tracker with recipes, meal plans, shopping lists, and zero cloud dependencies",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "backup": "bash scripts/backup.sh",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "test": "node --test --test-force-exit tests/*.test.js",
    "test:coverage": "c8 --reporter=text --reporter=lcov node --test --test-force-exit tests/*.test.js",
    "test:security": "node --test --test-force-exit tests/security.test.js tests/auth.test.js",
    "test:crud": "node --test --test-force-exit tests/recipes.test.js tests/meals.test.js tests/ingredients.test.js tests/shopping.test.js",
    "test:smoke": "node --test --test-force-exit tests/e2e-smoke.test.js",
    "audit": "npm audit --audit-level=high || true"
  },
  "keywords": [
    "meal-planner",
    "nutrition",
    "recipes",
    "self-hosted",
    "sqlite",
    "express"
  ],
  "author": "Learn by Exploration",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "type": "commonjs",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.8.0",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "multer": "^2.1.1",
    "pino": "^10.3.1",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "c8": "^11.0.0",
    "eslint": "^10.2.0",
    "pino-pretty": "^13.0.0",
    "supertest": "^7.1.0"
  }
}
